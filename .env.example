# Your tenant public key. Get it from the desk's Developers tab.
# `cpk_live_*` / `cpk_test_*` keys auto-route same-origin requests
# to hosted Cimplify in both dev and prod. Anything else (`mock-dev`,
# empty) falls back to the local `cimplify dev` mock.
NEXT_PUBLIC_CIMPLIFY_PUBLIC_KEY=mock-dev

# Demo mode. `DEMO_MODE=1` serves an embedded mock catalogue (the built-in
# `fashion` seed) entirely in-process, so you can push to Vercel and get a
# full, clickable store with NO backend and no live key. `DEMO_MODE=0` (or
# unset) uses the normal storefront: a real `cpk_live_*` key fetches live data.
# Pasting a real `cpk_*` key auto-disables demo mode even if this is 1.
DEMO_MODE=1

# Customer sign-in. Cimplify deploy can inject these automatically for hosted
# projects; set them manually for local/custom deployments.
# The public values let browser SDK components (including checkout) start
# OAuth, while the server values let route handlers validate callbacks and
# refresh sessions. They can usually be the same client/redirect pair.
# NEXT_PUBLIC_CIMPLIFY_CLIENT_ID=
# NEXT_PUBLIC_CIMPLIFY_REDIRECT_URI=http://localhost:3000/auth/callback
# NEXT_PUBLIC_CIMPLIFY_ISSUER=https://api.cimplify.io
# CIMPLIFY_CLIENT_ID=
# CIMPLIFY_REDIRECT_URI=http://localhost:3000/auth/callback
# CIMPLIFY_ISSUER=https://api.cimplify.io
# Deprecated compatibility only:
# CIMPLIFY_AUTH_URL=

# Optional. Forces a fixed canonical URL for sitemap.xml, robots.txt,
# OpenGraph, and llms.txt. Leave unset and the storefront derives the
# canonical from the request `Host` header automatically.
# NEXT_PUBLIC_SITE_URL=
